.map-page {
  min-height: 100vh;
  padding: 20rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: #f6f1e8;
  color: #192d24;
}

.map-search-card {
  height: 82rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(36, 62, 48, 0.1);
}

.map-search-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #2e6b4e;
  font-size: 23rpx;
  font-weight: 800;
}

.map-search-input {
  flex: 1;
  height: 100%;
  color: #192d24;
  font-size: 26rpx;
}

.guide-map {
  width: 100%;
  height: 620rpx;
  margin-top: 22rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 42rpx rgba(36, 62, 48, 0.14);
}

.map-control-panel {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.map-control {
  width: 92rpx;
  height: 54rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #244b38;
  background: rgba(255, 255, 255, 0.94);
  font-size: 23rpx;
  font-weight: 800;
}

.map-filter-scroll {
  width: 100%;
  margin: 22rpx 0 8rpx;
  white-space: nowrap;
}

.map-filter-inner {
  display: inline-flex;
  gap: 12rpx;
}

.map-filter-chip {
  display: inline-flex;
  padding: 13rpx 18rpx;
  border-radius: 999rpx;
  color: #607269;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(46, 107, 78, 0.14);
  font-size: 23rpx;
}

.map-filter-chip.is-active {
  color: #ffffff;
  background: #2e6b4e;
  border-color: #2e6b4e;
}

.map-route-card,
.map-point-card,
.map-list-item {
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(36, 62, 48, 0.09);
}

.map-route-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
}

.map-route-head,
.map-section-row,
.map-point-top,
.map-actions,
.map-list-item {
  display: flex;
  align-items: center;
}

.map-route-head,
.map-section-row,
.map-point-top {
  justify-content: space-between;
  gap: 20rpx;
}

.map-section-kicker {
  display: block;
  color: #7a5a24;
  font-size: 22rpx;
  font-weight: 800;
}

.map-route-title,
.map-section-title,
.map-point-title,
.map-list-title {
  display: block;
  color: #192d24;
  font-weight: 900;
  line-height: 1.3;
}

.map-route-title,
.map-section-title {
  margin-top: 4rpx;
  font-size: 32rpx;
}

.map-route-meta,
.map-count,
.map-point-tag,
.map-list-type {
  flex: 0 0 auto;
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  color: #2e6b4e;
  background: #e7f2e7;
  font-size: 22rpx;
  font-weight: 800;
}

.map-route-desc,
.map-point-desc,
.map-point-meta,
.map-list-desc {
  display: block;
  margin-top: 10rpx;
  color: #697970;
  font-size: 24rpx;
  line-height: 1.5;
}

.map-route-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.map-route-tags text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #865522;
  background: #fff0d8;
  font-size: 21rpx;
}

.map-section-row {
  margin: 34rpx 4rpx 18rpx;
}

.map-point-card {
  border-radius: 28rpx;
  overflow: hidden;
}

.map-point-cover {
  width: 100%;
  height: 210rpx;
  display: block;
  background: #dfe7dc;
}

.map-point-body {
  padding: 22rpx;
}

.map-point-title {
  font-size: 31rpx;
}

.map-actions {
  gap: 16rpx;
  margin-top: 20rpx;
}

.map-primary-btn,
.map-secondary-btn {
  flex: 1;
  height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.map-primary-btn {
  color: #ffffff;
  background: #2e6b4e;
}

.map-secondary-btn {
  color: #2e6b4e;
  background: #e7f2e7;
}

.map-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.map-list-item {
  padding: 20rpx;
  border-radius: 24rpx;
  gap: 16rpx;
}

.map-list-index {
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #2e6b4e;
  font-weight: 900;
}

.map-list-main {
  flex: 1;
  min-width: 0;
}

.map-list-title {
  font-size: 27rpx;
}

.map-list-desc {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}