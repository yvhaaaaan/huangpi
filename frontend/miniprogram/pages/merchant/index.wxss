page {
  background: #f5f6f5;
}

.mine-page {
  min-height: 100vh;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

.merchant-head {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx 28rpx;
  background: #fff;
}

.merchant-avatar {
  width: 104rpx;
  height: 104rpx;
  flex: none;
  border-radius: 12rpx;
  background: #e4e8e5;
}

.merchant-info {
  min-width: 0;
  margin-left: 22rpx;
}

.name-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.merchant-name {
  max-width: 440rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 31rpx;
  font-weight: 700;
}

.verified {
  padding: 4rpx 9rpx;
  border: 1rpx solid #b8d0bf;
  border-radius: 5rpx;
  color: #34704f;
  font-size: 17rpx;
}

.merchant-owner {
  display: block;
  margin-top: 12rpx;
  color: #8a938d;
  font-size: 21rpx;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 24rpx 20rpx;
  border-top: 1rpx solid #eef0ee;
  background: #fff;
}

.stats-row > view {
  position: relative;
  text-align: center;
}

.stats-row > view + view::before {
  content: "";
  position: absolute;
  left: 0;
  top: 7rpx;
  bottom: 7rpx;
  width: 1rpx;
  background: #eceeec;
}

.stat-value, .stat-label {
  display: block;
}

.stat-value {
  color: #253b2f;
  font-size: 32rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 4rpx;
  color: #8a938d;
  font-size: 20rpx;
}

.panel-tabs {
  display: flex;
  height: 90rpx;
  margin-top: 18rpx;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #e8ebe9;
  background: #fff;
}

.panel-tab {
  position: relative;
  min-width: 110rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 38rpx;
  color: #778179;
  font-size: 25rpx;
}

.panel-tab.is-active {
  color: #1f382b;
  font-weight: 700;
}

.panel-tab.is-active::after {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 0;
  height: 5rpx;
  border-radius: 3rpx;
  background: #34704f;
}

.panel-tab text {
  min-width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
  border-radius: 15rpx;
  color: #fff;
  background: #9aa39d;
  font-size: 17rpx;
}

.list-section {
  background: #fff;
}

.list-row {
  display: flex;
  align-items: center;
  min-height: 118rpx;
  padding: 22rpx 28rpx;
  box-sizing: border-box;
}

.list-row + .list-row {
  border-top: 1rpx solid #eef0ee;
}

.row-state {
  width: 12rpx;
  height: 12rpx;
  flex: none;
  border-radius: 50%;
  background: #d1a24e;
}

.row-state.urgent {
  background: #c45d52;
}

.message-type {
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  border-radius: 8rpx;
  color: #3f6f53;
  background: #edf2ee;
  font-size: 18rpx;
}

.row-main {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.row-title-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.row-title, .row-desc, .row-time {
  display: block;
}

.row-title {
  color: #25362d;
  font-size: 25rpx;
  font-weight: 600;
}

.row-desc {
  margin-top: 7rpx;
  overflow: hidden;
  color: #858f89;
  font-size: 20rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-time {
  margin-top: 7rpx;
  color: #a1a8a3;
  font-size: 18rpx;
}

.row-arrow {
  margin-left: 18rpx;
  color: #b4bab6;
  font-size: 38rpx;
}

.unread {
  width: 11rpx;
  height: 11rpx;
  flex: none;
  border-radius: 50%;
  background: #c65c50;
}

.plain-empty {
  padding: 110rpx 30rpx;
  text-align: center;
}

.empty-title, .empty-desc {
  display: block;
}

.empty-title {
  color: #5f6b64;
  font-size: 25rpx;
}

.empty-desc {
  margin-top: 10rpx;
  color: #a0a8a3;
  font-size: 20rpx;
}

.account-section {
  margin-top: 18rpx;
  background: #fff;
}

.account-row, .logout-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  box-sizing: border-box;
  font-size: 23rpx;
}

.account-row {
  color: #4a5850;
}

.account-row text:last-child {
  color: #909993;
}

.logout-row {
  justify-content: center;
  border-top: 1rpx solid #eef0ee;
  color: #a3433a;
}

.merchant-nav {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(104rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e4e8e5;
  box-sizing: border-box;
  background: #fff;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #8a938d;
  font-size: 19rpx;
}

.nav-item.is-active {
  color: #34704f;
}

.nav-icon {
  height: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}