page {
  background: #f5f6f5;
}

.edit-page {
  min-height: 100vh;
  padding-bottom: calc(230rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-intro {
  padding: 30rpx 28rpx 24rpx;
  background: #fff;
}

.intro-title, .intro-desc {
  display: block;
}

.intro-title {
  color: #23362c;
  font-size: 34rpx;
  font-weight: 700;
}

.intro-desc {
  margin-top: 8rpx;
  color: #8b948f;
  font-size: 21rpx;
}

.form-section {
  margin-top: 16rpx;
  padding: 28rpx;
  background: #fff;
}

.section-label {
  margin-bottom: 20rpx;
  color: #34463c;
  font-size: 25rpx;
  font-weight: 600;
}

.section-note {
  display: block;
  margin-top: 14rpx;
  color: #9aa29d;
  font-size: 19rpx;
}

.upload-grid {
  display: flex;
  gap: 16rpx;
}

.upload-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #edf0ee;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #bdc6c0;
  box-sizing: border-box;
  color: #7f8b84;
  background: #fafbfa;
}

.upload-plus {
  font-size: 42rpx;
  font-weight: 300;
  line-height: 1;
}

.upload-text {
  margin-top: 10rpx;
  font-size: 20rpx;
}

.upload-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  background: rgba(32, 41, 36, 0.7);
  font-size: 24rpx;
}

.fields-section {
  padding-top: 0;
  padding-bottom: 0;
}

.field-row {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #ecefec;
}

.fields-section > .field-row:last-child {
  border-bottom: 0;
}

.field-label {
  width: 150rpx;
  flex: none;
  color: #405047;
  font-size: 24rpx;
}

.required {
  margin-right: 5rpx;
  color: #bd5148;
}

.field-input {
  flex: 1;
  height: 100rpx;
  color: #23362c;
  font-size: 25rpx;
  text-align: right;
}

.picker-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: #33483c;
  font-size: 25rpx;
}

.picker-arrow {
  margin-left: 14rpx;
  color: #aeb5b0;
  font-size: 34rpx;
}

.textarea-row {
  position: relative;
  padding: 28rpx 0 42rpx;
}

.field-textarea {
  width: 100%;
  height: 210rpx;
  margin-top: 18rpx;
  color: #23362c;
  font-size: 25rpx;
  line-height: 1.6;
}

.word-count {
  position: absolute;
  right: 0;
  bottom: 20rpx;
  color: #a0a8a3;
  font-size: 18rpx;
}

.placeholder {
  color: #b0b7b2;
}

.submit-note {
  padding: 22rpx 28rpx;
  color: #929b95;
  font-size: 19rpx;
}

.bottom-actions {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: calc(104rpx + env(safe-area-inset-bottom));
  height: 104rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 12rpx 28rpx;
  border-top: 1rpx solid #e3e7e4;
  box-sizing: border-box;
  background: #fff;
}

.draft-button, .submit-button {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 25rpx;
  font-weight: 600;
}

.draft-button {
  width: 210rpx;
  color: #405047;
  border: 1rpx solid #cfd6d1;
  background: #fff;
}

.submit-button {
  flex: 1;
  color: #fff;
  background: #34704f;
}

.merchant-nav {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(104rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e4e8e5;
  box-sizing: border-box;
  background: #fff;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #8a938d;
  font-size: 19rpx;
}

.nav-item.is-active {
  color: #34704f;
}

.nav-icon {
  height: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}