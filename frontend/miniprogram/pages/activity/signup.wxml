<view class="page-shell soft-bg">
  <view class="page-hero card card-pad">
    <text class="section-kicker">SIGN UP</text>
    <text class="section-title">油茶文化体验活动</text>
    <text class="section-sub">请填写报名信息；姓名、手机号、报名人数必填。</text>
  </view>

  <view class="section-bar"><view class="section-text"><text class="section-kicker">FORM</text><text class="section-title">报名表</text></view></view>
  <view class="form-card">
    <text class="form-label">姓名</text><input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    <text class="form-label">手机号</text><input class="form-input" placeholder="请输入 11 位手机号" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
    <text class="form-label">报名人数</text><input class="form-input" placeholder="例如：2" type="number" value="{{count}}" bindinput="onCountInput" />
    <text class="form-label">备注</text><input class="form-input" placeholder="选填，如儿童年龄、特殊需求" value="{{remark}}" bindinput="onRemarkInput" />
    <view class="action-row"><view class="line-button" bindtap="onBackTap">返回</view><view class="primary-button" bindtap="onSubmitTap">提交报名</view></view>
  </view>
</view>
